# --- NEMD PHASE ---
unfix           1
reset_timestep  0

print "BOX_v4 lx=$(lx) ly=$(ly) lz=$(lz)"
BOX_v4 lx=32.556164423628985105 ly=32.556164423628985105 lz=325.5616442363053693

# NVE integration
fix             1 all nve

# Muller-Plathe: 20 slabs (odd slabs are possible in Monte carlo), swap every 100 steps
# At dt=0.0005 ps, swap interval = 100*0.0005 = 0.05 ps = 50 fs
fix             thermal all thermal/conductivity 100 z 20

# Temperature profile: 80 bins (4 per slab for resolution)
compute         chunks all chunk/atom bin/1d z lower 0.025 units reduced
fix             temp_profile all ave/chunk 10 500 5000 chunks temp file ../outputs/temp_profile_v4_L${LEN}.dat
fix             temp_profile all ave/chunk 10 500 5000 chunks temp file ../outputs/temp_profile_v4_L60.dat

thermo          10000
thermo_style    custom step temp pe ke etotal press f_thermal

# Establish steady state (200 ps = 400000 steps at dt=0.0005)
run             400000
