# --- NEMD PHASE ---
unfix           1
reset_timestep  0

print "BOX lx=$(lx) ly=$(ly) lz=$(lz)"
BOX lx=32.559791367344992352 ly=32.559791367344992352 lz=108.53263789114987503

# NVE integration
fix             1 all nve

# Muller-Plathe: swap velocities between hot/cold regions
# Use 10 slabs (not 20) for better statistics per slab
# Swap every 200 steps (not 100) for stability
fix             thermal all thermal/conductivity 200 z 10

# Temperature profile: 40 bins for resolution
compute         chunks all chunk/atom bin/1d z lower 0.025 units reduced
fix             temp_profile all ave/chunk 10 500 5000 chunks temp file ../outputs/temp_profile_L${LEN}_v3.dat
fix             temp_profile all ave/chunk 10 500 5000 chunks temp file ../outputs/temp_profile_L20_v3.dat

thermo          10000
thermo_style    custom step temp pe ke etotal press f_thermal

# Establish steady state (200 ps)
run             200000
