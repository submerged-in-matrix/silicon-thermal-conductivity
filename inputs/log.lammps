# ============================================
# Silicon Thermal Conductivity via NEMD (v3)
# Muller-Plathe reverse NEMD with safe parameters
# Usage: lmp -in in.si_thermal_v3 -var LEN 20
# ============================================

units           metal
atom_style      atomic
boundary        p p p

lattice         diamond 5.431
Lattice spacing in x,y,z = 5.431 5.431 5.431
region          box block 0 6 0 6 0 ${LEN}
region          box block 0 6 0 6 0 20
create_box      1 box
